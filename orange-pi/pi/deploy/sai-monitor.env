# /etc/sai-monitor/sai-monitor.env  (chmod 600)
BRIDGE_LISTEN=:49152
# Genera el token con: openssl rand -hex 32
BRIDGE_TOKEN=PEGA_AQUI_UN_TOKEN_LARGO
# Nombre legible del dispositivo (aparece en el autodescubrimiento de la LAN)
BRIDGE_NAME=SAI Orange Pi
# Opcional: contraseña de enrollment.
# Si se define, el dashboard puede obtener el token automáticamente tras
# descubrir la Pi (pidiendo esta contraseña al usuario). Mínimo 8 caracteres.
# Si se deja vacío o se omite, el método de enrollment queda desactivado
# y solo es posible copiar el token a mano.
# BRIDGE_ENROLLMENT_PASSWORD=cambia-esta-contraseña
# Origen EXACTO desde el que sirves el dashboard (sin barra final)
BRIDGE_ORIGINS=http://localhost:5500
NUT_ADDR=127.0.0.1:3493
BRIDGE_CACHE_TTL=1s
# Para HTTPS, descomenta y apunta a los certificados:
# BRIDGE_TLS_CERT=/etc/sai-monitor/cert.pem
# BRIDGE_TLS_KEY=/etc/sai-monitor/key.pem
